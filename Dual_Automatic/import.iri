-- Database Type Definitions and Field Aliases
type TruckDatabase is Database ("Truck")
	ID       : string;
	Pri_Wgt  : real;
	Sec_Wgt  : real;
	Ter_Wgt  : real;
	TimeDate : datetime;
	Scale    : integer;
	Keyed    : integer;
end database;

Truck_ID          : constant integer := 1;
Truck_Pri_Wgt     : constant integer := 2;
Truck_Sec_Wgt     : constant integer := 3;
Truck_Ter_Wgt     : constant integer := 4;
Truck_TimeDate    : constant integer := 5;
Truck_Scale       : constant integer := 6;
Truck_Keyed       : constant integer := 7;

type TotesDatabase is Database ("Totes")
	Ticket   : integer;
	ToteWt   : real;
	Station  : integer;
	TimeFill : datetime;
end database;

Totes_Ticket      : constant integer := 1;
Totes_ToteWt      : constant integer := 2;
Totes_Station     : constant integer := 3;
Totes_TimeFill    : constant integer := 4;

type SetupDatabase is Database ("Setup")
	Ticket   : integer;
	Target   : real;
	PreAct   : real;
	Band     : integer;
	SaveRec  : integer;
end database;

Setup_Ticket      : constant integer := 1;
Setup_Target      : constant integer := 2;
Setup_PreAct      : constant integer := 3;
Setup_Band        : constant integer := 4;
Setup_SaveRec     : constant integer := 5;



